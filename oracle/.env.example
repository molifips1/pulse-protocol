# Pulse oracle / detector environment
# Copy this to .env for local oracle work. Never commit real values.

# Supabase service credentials.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Oracle wallet and chain config.
ORACLE_PRIVATE_KEY=
VAULT_CONTRACT_ADDRESS=
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Optional MockUSDC mint endpoint support.
USDC_ADDRESS=

# Webhook auth shared with frontend API routes and detector.
WEBHOOK_SECRET=

# Optional frontend callback URL used by oracle/index.js.
FRONTEND_URL=

# Detector service config.
ORACLE_URL=http://localhost:3001
GROQ_API_KEY=
ANTHROPIC_API_KEY=
CHECK_INTERVAL=60

# Local service port.
PORT=3001

# Not currently read by oracle/detector code:
# - FRAME_INTERVAL
