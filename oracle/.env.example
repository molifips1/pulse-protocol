# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Oracle wallet (private key — NEVER commit this)
ORACLE_PRIVATE_KEY=0xYourOraclePrivateKey
ORACLE_SIGNER_ADDRESS=0xDerivedPublicAddress

# Contract
VAULT_CONTRACT_ADDRESS=0xYourVaultContractAddress
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Webhook auth
WEBHOOK_SECRET=change-this-to-a-long-random-secret
PORT=3001
