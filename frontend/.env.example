# Pulse frontend / Vercel environment
# Copy this to .env.local for local frontend work. Never commit real values.

# Browser-safe Supabase values. These are exposed in the client bundle.
# RLS must be correct before launch because client components read public market data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Browser-safe wallet connection ID. Public by design.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Server-only Supabase values used by Next API routes.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Server-only API/auth values used by admin, cron, oracle, and live-stream fallback routes.
WEBHOOK_SECRET=
CRON_SECRET=
ORACLE_URL=

# Optional local-only override for `next dev` / `next start`.
# Vercel sets its own runtime port.
PORT=3001

# Not currently read by frontend code:
# - NEXT_PUBLIC_VAULT_ADDRESS / NEXT_PUBLIC_USDC_ADDRESS
# - VAULT_CONTRACT_ADDRESS / USDC_ADDRESS
# The frontend currently hardcodes contract addresses in frontend/lib/wagmi.ts.
