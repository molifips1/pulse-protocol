# Browser-safe Supabase values. These are exposed in the client bundle.
# Keep Row Level Security enabled and never put service-role credentials here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase values. Configure these only in Vercel server env.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Browser-safe wallet / chain identifiers.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
NEXT_PUBLIC_VAULT_ADDRESS=0xYourVaultContractAddress
NEXT_PUBLIC_USDC_ADDRESS=0xYourMockUSDCAddress

# Server-only webhook auth.
WEBHOOK_SECRET=change-this-to-a-long-random-secret
CRON_SECRET=change-this-to-a-long-random-secret
ORACLE_URL=https://your-oracle-service.up.railway.app
